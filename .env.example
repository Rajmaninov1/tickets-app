## Copy this file to .env and adjust values as needed.
## This project is configured so Docker Compose reads EVERYTHING from a single .env.

# App
ENVIRONMENT=dev
BASE_URL=http://localhost:8000
SECRET_KEY=change-me
# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL (see Python logging docs)
LOG_LEVEL=INFO

# Postgres (used by the postgres container)
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# DB connection string used by the app container (host must be "postgres" in Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/app

# RabbitMQ connection string used by the app container (host must be "rabbitmq" in Docker)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
